<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- SMS: reception + parsing + outbound forwarding. Restricted perms; app
         distributes via sideload / non-Play channels. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Foreground notifications & service (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Network for email relay. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Biometric lock. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Ignore battery optimisation exemption prompt (OEM background kills). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".OtpForwarderApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OTPForwarder"
        tools:targetApi="34">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.OTPForwarder">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            SmsReceiver — listens for incoming SMS.
            android:exported="true" is required; the system telephony stack sends
            SMS_RECEIVED as an ordered broadcast to all registered receivers.
            We intentionally omit android:permission="BROADCAST_SMS" because on
            Samsung One UI (and several other OEMs) the telephony process does not
            hold BROADCAST_SMS when dispatching SMS_RECEIVED, which silently drops
            the broadcast. The system already restricts receipt to apps that hold
            the RECEIVE_SMS runtime permission, so no extra guard is needed here.
        -->
        <receiver
            android:name="com.samsung.android.otpforwarder.core.sms.SmsReceiver"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
